# AgentX Environment Variables
# Copy to .env and fill in your API keys.
# In Dokploy: set these in the Environment tab (they auto-write to .env).

# ── Required ──
OPENCODE_API_KEY=your-opencode-go-api-key
EXA_API_KEY=your-exa-api-key


# ── Optional ──
# CORS: comma-separated origins allowed to call the API (frontend origin in prod).
# Defaults to localhost dev ports if unset.
ALLOWED_ORIGINS=https://agentx.phloraxx.us.to,http://localhost:5173

# Docker sandbox socket (leave empty to use subprocess fallback on machines without Docker).
# DOCKER_HOST=unix:///var/run/docker.sock
